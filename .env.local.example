# ============================================================
#  KaggleGPT Environment Variables
# ============================================================

# ── Option A: New API Token (recommended) ──
# kaggle.com → Profile → Settings → API → "Generate New Token"
# Copy the token string shown on screen
VITE_KAGGLE_API_TOKEN=your_new_api_token_here
VITE_KAGGLE_USERNAME=your_kaggle_username

# ── Option B: Legacy credentials ──
# kaggle.com → Profile → Settings → API → "Create New Token" (Legacy section)
# Opens kaggle.json — copy username and key from it
# VITE_KAGGLE_USERNAME=username_from_kaggle_json
# VITE_KAGGLE_KEY=key_from_kaggle_json

# ── Groq API key (free at console.groq.com) ──
VITE_GROQ_API_KEY=your_groq_api_key
